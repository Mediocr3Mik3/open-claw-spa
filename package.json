{
  "name": "openclaw-spa",
  "version": "1.0.0",
  "description": "Signed Prompt Architecture — cryptographic authorization layer for OpenClaw AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "claw-spa": "dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc",
    "build:electron-main": "tsc -p tsconfig.electron.json",
    "build:electron-renderer": "vite build",
    "build:electron": "npm run build:electron-main && npm run build:electron-renderer",
    "build:all": "npm run build && npm run build:electron",
    "dev": "tsc --watch",
    "dev:renderer": "vite dev",
    "cli": "tsx src/cli/main.ts",
    "bridge": "tsx src/messaging/server.ts",
    "electron": "electron dist-electron/desktop/main/index.js",
    "electron:dev": "concurrently \"npm run dev\" \"npm run dev:renderer\" \"sleep 3 && npm run electron\"",
    "pack": "electron-builder --dir",
    "dist": "npm run build:all && electron-builder",
    "dist:mac": "npm run build:all && electron-builder --mac",
    "dist:win": "npm run build:all && electron-builder --win",
    "dist:linux": "npm run build:all && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts,.tsx",
    "clean": "rm -rf dist dist-electron dist-renderer"
  },
  "keywords": [
    "openclaw",
    "ai-security",
    "prompt-signing",
    "cryptographic-authorization",
    "agent-safety"
  ],
  "author": "Mediocr3Mik3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mediocr3Mik3/open-claw-spa.git"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "express": "^4.21.0",
    "jose": "^6.1.3",
    "keytar": "^7.9.0",
    "simple-git": "^3.32.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.0"
  },
  "optionalDependencies": {
    "electron": "^33.0.0",
    "expo-local-authentication": "^14.0.0",
    "expo-secure-store": "^13.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-native": "^0.75.0",
    "react-native-safe-area-context": "^4.14.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
